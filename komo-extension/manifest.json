{
  "manifest_version": 3,
  "name": "komo",
  "version": "0.1.0",
  "description": "your corner of the internet — sidebar navigation with folders, link saver, and command bar",
  "permissions": [
    "tabs",
    "storage",
    "downloads",
    "sidePanel",
    "bookmarks",
    "history"
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "commands": {
    "open-command-bar": {
      "suggested_key": { "default": "Ctrl+K", "mac": "Command+K" },
      "description": "Open command bar"
    },
    "save-link": {
      "suggested_key": { "default": "Ctrl+D", "mac": "Command+D" },
      "description": "Save current page"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
